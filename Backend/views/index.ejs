        document.getElementById('admin-fps-demand-inputs').innerHTML = fpsDemandHtml || '<div class="text-gray-500 text-sm">No grains available</div>';
        const deletable = Object.entries(db.locations || {}).filter(([_, loc]) => loc && loc.type !== 'godown');
        document.getElementById('admin-delete-select').innerHTML = '<option value="">-- Select Location --</option>' + deletable.map(([id, loc]) => `<option value="${id}">${loc.name} (${loc.type})</option>`).join('');
    }

    function showView(viewId) {
        // Check permission before showing view
        const permissionMap = {
            'dashboard-view': 'dashboard',
            'central-admin-view': 'central-admin',
            'godown-to-warehouse-view': 'godown-to-warehouse',
            'warehouse-to-cityhub-view': 'warehouse-to-cityhub',
            'cityhub-to-fps-view': 'cityhub-to-fps',
            'beneficiary-view': 'beneficiary',
            'transaction-view': 'transaction',
            'system-admin-view': 'system-admin'
        };
        
        const requiredPermission = permissionMap[viewId];
        if (requiredPermission && !userPermissions.includes(requiredPermission)) {
            showToast('You do not have permission to access this page', 'error');
            return;
        }
        
        document.querySelectorAll('.view-content').forEach(v => v.classList.add('hidden'));
        document.getElementById(viewId).classList.remove('hidden');
        document.querySelectorAll('.sidebar-link').forEach(link => link.classList.remove('active'));
        const activeLink = document.querySelector(`.sidebar-link[onclick*="${viewId}"]`);
        if (activeLink) activeLink.classList.add('active');
        const renderMap = { 'dashboard-view': renderDashboardView, 'central-admin-view': renderCentralAdminView, 'godown-to-warehouse-view': renderGodownToWarehouseView, 'warehouse-to-cityhub-view': renderWarehouseToCityHubView, 'cityhub-to-fps-view': renderCityHubToFPSView, 'beneficiary-view': renderBeneficiaryView, 'transaction-view': renderTransactionView, 'system-admin-view': renderSystemAdminView };
        if(renderMap[viewId]) renderMap[viewId]();
    }
    
