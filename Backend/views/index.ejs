xl font-bold text-gray-800 mb-6">Create New Locations</h2><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-lg font-bold mb-3 text-gray-700">1. Add State & Warehouse</h3><input type="text" id="admin-state-name" placeholder="New State Name" class="w-full border-gray-300 rounded-md p-2 mb-2"><input type="text" id="admin-warehouse-name" placeholder="Warehouse Name" class="w-full border-gray-300 rounded-md p-2 mb-3"><button onclick="addStateWarehouse()" class="w-full bg-indigo-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-indigo-700 transition"><i class="fas fa-plus mr-2"></i>Create State</button></div><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-lg font-bold mb-3 text-gray-700">2. Add City Hub</h3><select id="admin-city-state-select" class="w-full border-gray-300 rounded-md p-2 mb-2"></select><input type="text" id="admin-hub-name" placeholder="City Hub Name" class="w-full border-gray-300 rounded-md p-2 mb-3"><button onclick="addCityHub()" class="w-full bg-indigo-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-indigo-700 transition"><i class="fas fa-plus mr-2"></i>Create Hub</button></div><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-lg font-bold mb-3 text-gray-700">Add Central Godown</h3><input type="text" id="admin-godown-name" placeholder="e.g., FCI Central" class="w-full border-gray-300 rounded-md p-2 mb-3"><button onclick="addCentralGodown()" class="w-full bg-indigo-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-indigo-700 transition"><i class="fas fa-plus mr-2"></i>Create Godown</button></div></div></div><div class="bg-white rounded-xl shadow-lg p-6 md:p-8"><h2 class="text-3xl font-bold text-gray-800 mb-6">Create Fair Price Shop (FPS)</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div><label class="font-semibold text-gray-600">1. Select State & City</label><select id="admin-fps-state-select" class="w-full border-gray-300 rounded-md p-2 mt-1 mb-2"></select><select id="admin-fps-city-select" class="w-full border-gray-300 rounded-md p-2 mt-1"></select></div><div><label class="font-semibold text-gray-600">2. Enter FPS Details</label><input type="text" id="admin-fps-name" placeholder="FPS Name" class="w-full border-gray-300 rounded-md p-2 mt-1"></div><div><label class="font-semibold text-gray-600">3. Set Monthly Demand (Kgs)</label><div id="admin-fps-demand-inputs" class="space-y-1 mt-1"></div></div></div><button onclick="addFPS()" class="w-full mt-6 bg-green-600 text-white font-bold py-3 px-4 rounded-lg hover:bg-green-700 transition text-lg"><i class="fas fa-store mr-2"></i>Create FPS</button></div><div class="bg-white rounded-xl shadow-lg p-6 md:p-8"><h2 class="text-3xl font-bold text-red-700 mb-6">Delete Location</h2><p class="text-gray-600 mb-4 -mt-4">Warning: Deleting a location is permanent. Central Godowns cannot be deleted.</p><div class="flex items-center space-x-4"><select id="admin-delete-select" class="w-full border-gray-300 rounded-md p-3"></select><button onclick="deleteLocation()" class="bg-red-600 text-white font-bold py-2 px-6 rounded-lg hover:bg-red-700 transition"><i class="fas fa-trash-alt mr-2"></i>Delete</button></div></div></div>`
        };
        for (const viewId in viewTemplates) {
            if (document.getElementById(viewId)) {
                document.getElementById(viewId).innerHTML = viewTemplates[viewId];
            }
        }
        
        // Load data from Firebase on page load
        loadDBFromFirebase().then(() => {
            document.getElementById('beneficiary-reg-state-select').addEventListener('change', renderBeneficiaryView);
            document.getElementById('beneficiary-reg-city-select').addEventListener('change', renderBeneficiaryView);
            document.getElementById('dist-state-select').addEventListener('change', renderBeneficiaryView);
            document.getElementById('dist-city-select').addEventListener('change', renderBeneficiaryView);
            document.getElementById('dist-fps-select').addEventListener('change', renderBeneficiaryView);
            document.getElementById('dist-beneficiary-select').addEventListener('change', renderBeneficiaryView);
            document.getElementById('dist-from-select').addEventListener('change', renderStateAdminView);
            document.getElementById('dist-to-select').addEventListener('change', renderStateAdminView);
            
            showView('dashboard-view');
        });
    });
    </script>
