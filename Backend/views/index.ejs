<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JustRation - PDS Supply Chain Dashboard</title>
    
    <!-- Load CSS/JS resources FIRST -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Authentication Check -->
    <script>
        (function() {
            const currentUser = JSON.parse(localStorage.getItem('currentUser') || 'null');
            if (!currentUser) {
                window.location.replace('/login');
                throw new Error('Not authenticated');
            }
        })();
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f0f4f8;
        }
        .sidebar-link {
            transition: all 0.2s ease-in-out;
        }
        .sidebar-link.active, .sidebar-link:hover {
            background-color: #4f46e5;
            color: white;
            transform: scale(1.05);
            box-shadow: 0 4px 14px 0 rgba(0, 0, 0, 0.1);
        }
        .fade-in { animation: fadeIn 0.5s ease-in-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .toast {
            position: fixed; bottom: 20px; right: 20px; padding: 1rem 1.5rem;
            border-radius: 0.5rem; color: white; z-index: 1000; opacity: 0;
            transform: translateY(20px); transition: all 0.3s ease;
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }
        .toast.show { opacity: 1; transform: translateY(0); }
        .toast.success { background: linear-gradient(to right, #10b981, #34d399); }
        .toast.error { background: linear-gradient(to right, #ef4444, #f87171); }
        .toast.info { background: linear-gradient(to right, #3b82f6, #60a5fa); }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #e2e8f0; }
        ::-webkit-scrollbar-thumb { background: #a0aec0; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #718096; }
        
        .stat-card { transition: all 0.3s ease; }
        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1); }
    </style>
</head>
<body class="flex h-screen text-gray-800">

    <aside class="w-20 lg:w-64 bg-white shadow-lg flex-shrink-0 flex flex-col">
        <div class="h-20 flex items-center justify-center bg-gradient-to-r from-blue-600 to-indigo-600 text-white">
            <i class="fas fa-cubes-stacked text-3xl lg:mr-3"></i>
            <span class="text-2xl font-extrabold hidden lg:inline">JustRation</span>
        </div>
        
        <!-- User Profile -->
        <div id="user-profile" class="px-4 py-4 border-b bg-gray-50 hidden lg:block">
            <div class="flex items-center space-x-3">
                <div class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold">
                    <span id="user-initial">A</span>
                </div>
                <div class="flex-1">
                    <div class="font-bold text-gray-800 text-sm" id="user-name">User</div>
                    <div class="text-xs text-gray-500" id="user-role">Role</div>
                </div>
            </div>
        </div>
        
        <nav class="mt-4 flex-1" id="sidebar-nav">
            <a onclick="showView('dashboard-view')" class="sidebar-link active flex items-center justify-center lg:justify-start py-3 px-6 text-gray-600 font-semibold rounded-lg mx-2 lg:mx-4 my-1" data-permission="dashboard">
                <i class="fas fa-tachometer-alt w-6 text-center lg:mr-3"></i><span class="hidden lg:inline">Dashboard</span>
            </a>
            <a onclick="showView('central-admin-view')" class="sidebar-link flex items-center justify-center lg:justify-start py-3 px-6 text-gray-600 font-semibold rounded-lg mx-2 lg:mx-4 my-1" data-permission="central-admin">
                <i class="fas fa-warehouse w-6 text-center lg:mr-3"></i><span class="hidden lg:inline">Central Stock</span>
            </a>
            <a onclick="showView('godown-to-warehouse-view')" class="sidebar-link flex items-center justify-center lg:justify-start py-3 px-6 text-gray-600 font-semibold rounded-lg mx-2 lg:mx-4 my-1" data-permission="godown-to-warehouse">
                <i class="fas fa-arrow-right w-6 text-center lg:mr-3"></i><span class="hidden lg:inline text-xs">Godown→Warehouse</span>
            </a>
            <a onclick="showView('warehouse-to-cityhub-view')" class="sidebar-link flex items-center justify-center lg:justify-start py-3 px-6 text-gray-600 font-semibold rounded-lg mx-2 lg:mx-4 my-1" data-permission="warehouse-to-cityhub">
                <i class="fas fa-arrow-right w-6 text-center lg:mr-3"></i><span class="hidden lg:inline text-xs">Warehouse→City</span>
            </a>
            <a onclick="showView('cityhub-to-fps-view')" class="sidebar-link flex items-center justify-center lg:justify-start py-3 px-6 text-gray-600 font-semibold rounded-lg mx-2 lg:mx-4 my-1" data-permission="cityhub-to-fps">
                <i class="fas fa-arrow-right w-6 text-center lg:mr-3"></i><span class="hidden lg:inline text-xs">City→FPS</span>
            </a>
            <a onclick="showView('beneficiary-view')" class="sidebar-link flex items-center justify-center lg:justify-start py-3 px-6 text-gray-600 font-semibold rounded-lg mx-2 lg:mx-4 my-1" data-permission="beneficiary">
                <i class="fas fa-users w-6 text-center lg:mr-3"></i><span class="hidden lg:inline">Distribution</span>
            </a>
            <a onclick="showView('transaction-view')" class="sidebar-link flex items-center justify-center lg:justify-start py-3 px-6 text-gray-600 font-semibold rounded-lg mx-2 lg:mx-4 my-1" data-permission="transaction">
                <i class="fas fa-receipt w-6 text-center lg:mr-3"></i><span class="hidden lg:inline">Ledger</span>
            </a>
            <a onclick="showView('system-admin-view')" class="sidebar-link flex items-center justify-center lg:justify-start py-3 px-6 text-gray-600 font-semibold rounded-lg mx-2 lg:mx-4 my-1" data-permission="system-admin">
                <i class="fas fa-cogs w-6 text-center lg:mr-3"></i><span class="hidden lg:inline">Administration</span>
            </a>
        </nav>
        
        <!-- Logout Button -->
        <div class="p-4 border-t">
            <button onclick="handleLogout()" class="w-full bg-red-500 hover:bg-red-600 text-white font-semibold py-2 px-4 rounded-lg transition duration-300 flex items-center justify-center">
                <i class="fas fa-sign-out-alt lg:mr-2"></i>
                <span class="hidden lg:inline">Logout</span>
            </button>
        </div>
    </aside>

    <main class="flex-1 p-6 md:p-10 overflow-y-auto">
        <div id="dashboard-view" class="view-content fade-in"></div>
        <div id="central-admin-view" class="view-content hidden fade-in"></div>
        <div id="godown-to-warehouse-view" class="view-content hidden fade-in"></div>
        <div id="warehouse-to-cityhub-view" class="view-content hidden fade-in"></div>
        <div id="cityhub-to-fps-view" class="view-content hidden fade-in"></div>
        <div id="beneficiary-view" class="view-content hidden fade-in"></div>
        <div id="transaction-view" class="view-content hidden fade-in"></div>
        <div id="system-admin-view" class="view-content hidden fade-in"></div>
    </main>

    <div id="toast" class="toast"></div>

    <script src="/script.js"></script>
    <script>
    // Get user from authentication check
    const currentUser = JSON.parse(localStorage.getItem('currentUser'));
    const userPermissions = currentUser.permissions;
    
    let charts = {};
    let db = {};
    let isLoading = false;

    // Initialize user profile display
    function initializeUserProfile() {
        if (currentUser) {
            document.getElementById('user-initial').textContent = currentUser.name.charAt(0).toUpperCase();
            document.getElementById('user-name').textContent = currentUser.name;
            document.getElementById('user-role').textContent = currentUser.role.charAt(0).toUpperCase() + currentUser.role.slice(1);
            
            // Filter navigation based on permissions
            filterNavigationByRole();
        }
    }

    function filterNavigationByRole() {
        const allLinks = document.querySelectorAll('.sidebar-link');
        allLinks.forEach(link => {
            const permission = link.getAttribute('data-permission');
            if (permission && !userPermissions.includes(permission)) {
                link.style.display = 'none';
            }
        });
    }

    function handleLogout() {
        if (confirm('Are you sure you want to logout?')) {
            localStorage.removeItem('currentUser');
            window.location.href = '/login';
        }
    }

    function normalizePhoneNumber(phoneNumber) {
        if (!phoneNumber) return '';

        let normalized = String(phoneNumber).trim().replace(/[\s\-()]/g, '');
        if (!normalized) return '';

        if (normalized.startsWith('00')) {
            normalized = `+${normalized.slice(2)}`;
        }

        if (/^\d{10}$/.test(normalized)) {
            normalized = `+91${normalized}`;
        }

        if (/^\d{8,15}$/.test(normalized) && !normalized.startsWith('+')) {
            normalized = `+${normalized}`;
        }

        return /^\+[1-9]\d{7,14}$/.test(normalized) ? normalized : '';
    }

    function normalizeBeneficiaryRecord(beneficiary) {
        const normalizedId = beneficiary.ration_card_id || beneficiary.rationCardId || beneficiary.id;
        return {
            ...beneficiary,
            id: beneficiary.id || normalizedId,
            rationCardId: normalizedId,
            fpsId: beneficiary.fpsId || beneficiary.fps_id,
            phoneNumber: beneficiary.phoneNumber || beneficiary.phone_number || ''
        };
    }

    function ensureBeneficiaryPhoneInput() {
        if (document.getElementById('beneficiary-phone')) return;

        const nameInput = document.getElementById('beneficiary-name');
        const rationInput = document.getElementById('beneficiary-ration-id');
        if (!nameInput || !rationInput) return;

        const formGrid = nameInput.closest('.grid');
        if (formGrid) {
            formGrid.classList.remove('md:grid-cols-2');
            formGrid.classList.add('md:grid-cols-3');
        }

        const phoneField = document.createElement('div');
        phoneField.innerHTML = `<label class="font-semibold text-gray-600">Phone Number</label><input id="beneficiary-phone" type="tel" placeholder="e.g., +919876543210" class="w-full border-gray-300 rounded-md p-3 mt-1">`;

        if (formGrid) {
            formGrid.appendChild(phoneField);
        }
    }

    async function loadDBFromSupabase() {
        if (isLoading) return;
        isLoading = true;
        try {
            const data = await fetchAllData();
            if (data) {
                db.locations = {};
                db.beneficiaries = {};
                db.grains = data.grains && Array.isArray(data.grains) && data.grains.length > 0
                    ? data.grains.filter(g => g && typeof g === 'string')
                    : ['Wheat', 'Rice', 'Sugar'];
                db.transactions = data.transactions || [];
                
                if (Array.isArray(data.locations)) {
                    data.locations.forEach(loc => {
                        db.locations[loc.id] = loc;
                    });
                }
                
                if (Array.isArray(data.beneficiaries)) {
                    data.beneficiaries.forEach(ben => {
                        const normalizedBeneficiary = normalizeBeneficiaryRecord(ben);
                        db.beneficiaries[normalizedBeneficiary.rationCardId] = normalizedBeneficiary;
                    });
                }
                
                console.log('✓ Data loaded from database:', db);
            }
        } catch (error) {
            console.error('Error loading data from database:', error);
            showToast('Failed to load data. Using defaults.', 'error');
            // Set default values
            db.grains = ['Wheat', 'Rice', 'Sugar'];
            db.transactions = [];
            db.locations = {};
            db.beneficiaries = {};
        }
        isLoading = false;
    }

    function saveDB(data) {
        // Data is automatically saved to Supabase via API endpoints
        console.log('Data saved to database');
    }
    
    function showToast(message, type = 'success') {
        const toast = document.getElementById('toast');
        toast.textContent = message;
        toast.className = `toast show ${type}`;
        setTimeout(() => { toast.className = 'toast'; }, 3000);
    }

    function generateId(name) {
        return name.toLowerCase().replace(/[^a-z0-9]+/g, '-') + '-' + Date.now().toString(36).slice(-4);
    }
    
    function logAdminAction(action, details) {
        db.transactions.unshift({
            hash: `0x${Math.random().toString(36).substr(2, 10)}...${Math.random().toString(36).substr(2, 4)}`,
            timestamp: new Date().toLocaleString(), from: 'System Admin', to: action, items: details, type: 'admin'
        });
    }

    function addStock() {
        const godownId = document.getElementById('central-godown-select').value;
        const grain = document.getElementById('central-grain-select').value;
        const quantity = parseInt(document.getElementById('central-quantity-input').value, 10);
        if (!godownId || !grain || !quantity || quantity <= 0) { 
            showToast('Please fill all fields with valid data.', 'error'); 
            return; 
        }
        
        addStockToDB(godownId, grain, quantity).then(result => {
            if (result && !result.error) {
                document.getElementById('central-quantity-input').value = '';
                renderCentralAdminView();
                showToast(`${quantity.toLocaleString()} Kgs of ${grain} added successfully!`, 'success');
                loadDBFromSupabase();
            } else if (result && result.message) {
                showToast(result.message, 'error');
            }
        });
    }

    function dispatchGodownToWarehouse() {
        const fromId = document.getElementById('g2w-from-select').value;
        const toId = document.getElementById('g2w-to-select').value;
        const grain = document.getElementById('g2w-grain-select')?.value;
        const quantity = parseInt(document.getElementById('g2w-quantity-input')?.value, 10);
        if (!fromId || !toId || !grain || !quantity || quantity <= 0) { 
            showToast('Please complete all fields.', 'error'); 
            return; 
        }
        
        dispatchToDB(fromId, toId, grain, quantity).then(result => {
            if (result && !result.error) {
                showToast('Stock transferred from Godown to Warehouse successfully!', 'success');
                renderGodownToWarehouseView();
                loadDBFromSupabase();
            } else if (result && result.message) {
                showToast(result.message, 'error');
            }
        });
    }

    function dispatchWarehouseToCityHub() {
        const fromId = document.getElementById('w2c-from-select').value;
        const toId = document.getElementById('w2c-to-select').value;
        const grain = document.getElementById('w2c-grain-select')?.value;
        const quantity = parseInt(document.getElementById('w2c-quantity-input')?.value, 10);
        if (!fromId || !toId || !grain || !quantity || quantity <= 0) { 
            showToast('Please complete all fields.', 'error'); 
            return; 
        }
        
        dispatchToDB(fromId, toId, grain, quantity).then(result => {
            if (result && !result.error) {
                showToast('Stock transferred from Warehouse to City Hub successfully!', 'success');
                renderWarehouseToCityHubView();
                loadDBFromSupabase();
            } else if (result && result.message) {
                showToast(result.message, 'error');
            }
        });
    }

    function dispatchCityHubToFPS() {
        const fromId = document.getElementById('c2f-from-select').value;
        const toId = document.getElementById('c2f-to-select').value;
        const grain = document.getElementById('c2f-grain-select')?.value;
        const quantity = parseInt(document.getElementById('c2f-quantity-input')?.value, 10);
        if (!fromId || !toId || !grain || !quantity || quantity <= 0) { 
            showToast('Please complete all fields.', 'error'); 
            return; 
        }
        
        dispatchToDB(fromId, toId, grain, quantity).then(result => {
            if (result && !result.error) {
                showToast('Stock transferred from City Hub to FPS successfully!', 'success');
                renderCityHubToFPSView();
                loadDBFromSupabase();
            } else if (result && result.message) {
                showToast(result.message, 'error');
            }
        });
    }

    function executeTransaction(fromId, toId, itemsToSend) {
        const fromLocation = db.locations[fromId];
        for (const grain in itemsToSend) {
            if (itemsToSend[grain] > (fromLocation.stock[grain] || 0)) {
                showToast(`Not enough stock for ${grain} at ${fromLocation.name}.`, 'error'); return false;
            }
        }
        for (const grain in itemsToSend) {
            fromLocation.stock[grain] -= itemsToSend[grain];
            if (db.locations[toId]) {
                 db.locations[toId].stock[grain] = (db.locations[toId].stock[grain] || 0) + itemsToSend[grain];
            }
        }
        const toName = db.locations[toId] ? db.locations[toId].name : (db.beneficiaries[toId] ? `Beneficiary: ${db.beneficiaries[toId].name} (${toId})` : toId);
        db.transactions.unshift({
            hash: `0x${Math.random().toString(36).substr(2, 10)}...${Math.random().toString(36).substr(2, 4)}`,
            timestamp: new Date().toLocaleString(), from: fromLocation.name, to: toName,
            items: itemsToSend, type: 'transfer'
        });
        return true;
    }

    function registerBeneficiary() {
        const name = document.getElementById('beneficiary-name').value.trim();
        const rationCardId = document.getElementById('beneficiary-ration-id').value.trim().toUpperCase();
        const fpsId = document.getElementById('beneficiary-reg-fps-select').value;
        const phoneInput = document.getElementById('beneficiary-phone');
        const phoneNumber = normalizePhoneNumber(phoneInput ? phoneInput.value : '');
        if (!name || !rationCardId || !fpsId || !phoneNumber) {
            showToast('Please fill all fields with a valid phone number.', 'error');
            return;
        }
        
        addBeneficiaryToDB(name, rationCardId, fpsId, phoneNumber).then(result => {
            if (result && !result.error) {
                showToast(`Beneficiary ${name} registered successfully!`, 'success');
                document.getElementById('beneficiary-name').value = '';
                document.getElementById('beneficiary-ration-id').value = '';
                if (phoneInput) phoneInput.value = '';
                renderBeneficiaryView();
                loadDBFromSupabase();
            } else if (result && result.message) {
                showToast(result.message, 'error');
            }
        });
    }

    function distributeRation() {
        const fpsId = document.getElementById('dist-fps-select').value;
        const beneficiaryId = document.getElementById('dist-beneficiary-select').value;
        const grainToDistribute = document.getElementById('beneficiary-grain-select')?.value;
        const quantityToDistribute = parseInt(document.getElementById('beneficiary-quantity-input')?.value, 10);
        
        if (!fpsId || !beneficiaryId) { 
            showToast('Please select an FPS and a beneficiary.', 'error'); 
            return; 
        }
        if (!grainToDistribute || !quantityToDistribute || quantityToDistribute <= 0) { 
            showToast('Please select a grain and enter a valid quantity.', 'error'); 
            return; 
        }
        
        // Validate against max allowed (capped at 100 kg per distribution)
        const ben = db.beneficiaries[beneficiaryId];
        const fpsStock = db.locations[fpsId].stock;
        const maxAllowed = Math.min(ben.entitlement[grainToDistribute] || 0, fpsStock[grainToDistribute] || 0, 100);
        
        if (quantityToDistribute > maxAllowed) {
            showToast(`Quantity exceeds maximum allowed (${maxAllowed} Kgs, max 100 Kgs per distribution)`, 'error');
            return;
        }
        
        distributeToDB(fpsId, beneficiaryId, grainToDistribute, quantityToDistribute).then(result => {
            if (result && !result.error) {
                const smsSummary = result.smsSent ? 'SMS sent for beneficiary confirmation.' : 'SMS confirmation pending setup.';
                showToast(`${quantityToDistribute} Kgs of ${grainToDistribute} distributed. ${smsSummary}`, result.smsSent ? 'success' : 'info');
                renderBeneficiaryView();
                loadDBFromSupabase();
            } else if (result && result.message) {
                showToast(result.message, 'error');
            }
        });
    }

    function updateMaxQuantity() {
        const grainSelect = document.getElementById('beneficiary-grain-select');
        const quantityInput = document.getElementById('beneficiary-quantity-input');
        const maxDisplay = document.getElementById('max-quantity-display');
        
        if (grainSelect && quantityInput && maxDisplay) {
            const selectedOption = grainSelect.options[grainSelect.selectedIndex];
            const maxAllowed = parseInt(selectedOption.getAttribute('data-max') || 0);
            quantityInput.max = maxAllowed;
            maxDisplay.textContent = maxAllowed;
        }
    }

    function addGrain() {
        const grainNameInput = document.getElementById('admin-grain-name');
        const grainName = grainNameInput.value.trim();
        if(!grainName) { showToast('Please enter a grain name.', 'error'); return; }
        if(db.grains && db.grains.filter(g => g).map(g => g.toLowerCase()).includes(grainName.toLowerCase())) { showToast('This grain type already exists.', 'error'); return; }
        
        addGrainToDB(grainName).then(result => {
            if (result && !result.error) {
                showToast(`Grain type '${grainName}' added successfully!`, 'success');
                grainNameInput.value = '';
                loadDBFromSupabase().then(() => renderSystemAdminView());
            }
        });
    }

    function removeGrain(grainToRemove) {
        if(confirm(`Are you sure you want to remove '${grainToRemove}'? This will not delete existing stock records.`)) {
            removeGrainFromDB(grainToRemove).then(result => {
                if (result && !result.error) {
                    showToast(`Grain type '${grainToRemove}' removed successfully!`, 'success');
                    loadDBFromSupabase().then(() => renderSystemAdminView());
                } else if (result && result.message) {
                    showToast(result.message, 'error');
                }
            });
        }
    }

    function addCentralGodown() {
        const name = document.getElementById('admin-godown-name').value.trim();
        if (!name) { showToast('Please enter a godown name.', 'error'); return; }
        const id = generateId(name);
        db.locations[id] = { name, type: 'godown', stock: {} };
        logAdminAction('Create Godown', name);
        saveDB(db);
        showToast('Central Godown created.', 'success');
        renderSystemAdminView();
    }

    function addStateWarehouse() {
        const stateName = document.getElementById('admin-state-name').value.trim();
        const warehouseName = document.getElementById('admin-warehouse-name').value.trim();
        if (!stateName || !warehouseName) { showToast('Please provide both names.', 'error'); return; }
        const id = generateId(warehouseName);
        db.locations[id] = { name: warehouseName, type: 'warehouse', state: stateName, stock: {} };
        logAdminAction('Create State Warehouse', `${warehouseName} [${stateName}]`);
        saveDB(db);
        showToast('State and Warehouse created.', 'success');
        renderSystemAdminView();
    }

    function addCityHub() {
        const state = document.getElementById('admin-city-state-select').value;
        const hubName = document.getElementById('admin-hub-name').value.trim();
        if (!state || !hubName) { showToast('Please select state and provide name.', 'error'); return; }
        const cityName = hubName.split(' ')[0];
        const id = generateId(hubName);
        db.locations[id] = { name: hubName, type: 'city-hub', state, city: cityName, stock: {} };
        logAdminAction('Create City Hub', `${hubName} [${state}]`);
        saveDB(db);
        showToast('City Hub created.', 'success');
        renderSystemAdminView();
    }
    
    function addFPS() {
        const state = document.getElementById('admin-fps-state-select').value;
        const city = document.getElementById('admin-fps-city-select').value;
        const name = document.getElementById('admin-fps-name').value.trim();
        if (!state || !city || !name) { showToast('Please complete all FPS fields.', 'error'); return; }
        
        const locId = `fps-${Date.now()}`;
        addLocationToDB(locId, name, 'fps', state, city, {}).then(result => {
            if (result) {
                showToast('Fair Price Shop created successfully!', 'success');
                document.getElementById('admin-fps-name').value = '';
                loadDBFromSupabase().then(() => renderSystemAdminView());
            }
        });
    }

    function deleteLocation() {
        const locationId = document.getElementById('admin-delete-select').value;
        if (!locationId) { showToast('Please select a location to delete.', 'error'); return; }
        const locationName = db.locations[locationId] ? db.locations[locationId].name : locationId;
        if (confirm(`Are you sure you want to permanently delete "${locationName}"?`)) {
            deleteLocationFromDB(locationId).then(result => {
                if (result && !result.error) {
                    showToast('Location deleted successfully!', 'success');
                    loadDBFromSupabase().then(() => {
                        renderSystemAdminView();
                        renderStateAdminView();
                        renderBeneficiaryView();
                    });
                } else if (result && result.message) {
                    showToast(result.message, 'error');
                }
            });
        }
    }

    function exportData() {
        const dataStr = JSON.stringify(db, null, 2);
        const dataBlob = new Blob([dataStr], {type: "application/json"});
        const url = URL.createObjectURL(dataBlob);
        const link = document.createElement('a');
        link.download = `justration_backup_${new Date().toISOString().slice(0,10)}.json`;
        link.href = url;
        link.click();
        URL.revokeObjectURL(url);
        showToast('Data exported successfully!', 'success');
    }

    function importData(event) {
        const file = event.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const importedDb = JSON.parse(e.target.result);
                if (importedDb.locations && importedDb.beneficiaries && importedDb.grains && importedDb.transactions) {
                    db = importedDb;
                    saveDB(db);
                    showToast('Data imported successfully!', 'success');
                    showView(document.querySelector('.sidebar-link.active').getAttribute('onclick').match(/'(.*?)'/)[1]);
                } else {
                    showToast('Invalid data file format.', 'error');
                }
            } catch (error) {
                showToast('Error reading or parsing file.', 'error');
            }
        };
        reader.readAsText(file);
    }
    
    function renderDashboardView() {
        const totalStock = Object.values(db.locations || {}).reduce((acc, loc) => acc + Object.values(loc.stock || {}).reduce((s, q) => s + q, 0), 0);
        const totalBeneficiaries = Object.keys(db.beneficiaries || {}).length;
        const totalTransactions = (db.transactions || []).length;
        const grainStock = (db.grains || []).filter(g => g).map(grain => Object.values(db.locations || {}).reduce((sum, loc) => sum + ((loc.stock && loc.stock[grain]) || 0), 0));
        if (charts.grainStockChart) charts.grainStockChart.destroy();
