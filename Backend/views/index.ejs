ld text-gray-600 text-sm">City</label><select id="dist-city-select" class="w-full border-gray-300 rounded-md p-3 mt-1" disabled></select></div><div><label class="font-semibold text-gray-600 text-sm">FPS</label><select id="dist-fps-select" class="w-full border-gray-300 rounded-md p-3 mt-1" disabled></select></div><div><label class="font-semibold text-gray-600 text-sm">Beneficiary</label><select id="dist-beneficiary-select" class="w-full border-gray-300 rounded-md p-3 mt-1" disabled></select></div></div></div><div><h3 class="text-lg font-semibold text-gray-700 mb-2">2. Available Stock & Distribution</h3><div class="mt-4 bg-gray-50 p-4 rounded-lg border h-32 overflow-y-auto"><h4 class="font-semibold mb-2">FPS Stock:</h4><div id="dist-fps-stock-display" class="space-y-1 text-sm">Select an FPS to see stock.</div></div><div class="mt-4 bg-blue-50 p-4 rounded-lg border border-blue-200"><h4 class="font-semibold mb-2 text-blue-800">3. Select Grain and Quantity</h4><div id="beneficiary-distribution-inputs" class="space-y-3">Select a beneficiary to see their ration.</div></div></div></div><div class="mt-6"><button onclick="distributeRation()" class="w-full bg-green-600 text-white font-bold py-3 px-4 rounded-lg hover:bg-green-700 transition duration-300 text-lg"><i class="fas fa-hand-holding-heart mr-2"></i>Distribute Ration & Record</button></div></div></div>`,
            'transaction-view': `<div class="bg-white rounded-xl shadow-lg p-6 md:p-8"><h2 class="text-3xl font-bold text-gray-800 mb-6">Blockchain Transaction Ledger</h2><p class="text-gray-600 mb-6 -mt-4">Complete, immutable history of all stock movements and administrative actions.</p><div class="overflow-x-auto"><table class="min-w-full bg-white"><thead><tr class="bg-gray-50"><th class="text-left py-3 px-4 font-semibold text-sm text-gray-600 uppercase tracking-wider">Txn Hash</th><th class="text-left py-3 px-4 font-semibold text-sm text-gray-600 uppercase tracking-wider">Timestamp</th><th class="text-left py-3 px-4 font-semibold text-sm text-gray-600 uppercase tracking-wider">From / Actor</th><th class="text-left py-3 px-4 font-semibold text-sm text-gray-600 uppercase tracking-wider">To / Action</th><th class="text-left py-3 px-4 font-semibold text-sm text-gray-600 uppercase tracking-wider">Items / Details</th></tr></thead><tbody id="ledger-transaction-history-body" class="text-gray-700"></tbody></table></div></div>`,
            'system-admin-view': `<div class="space-y-8"><div class="bg-white rounded-xl shadow-lg p-6 md:p-8"><h2 class="text-3xl font-bold text-gray-800 mb-6">Data Management</h2><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-xl font-bold mb-3 text-gray-700">Export Data</h3><p class="text-sm text-gray-600 mb-4">Save all current data to a JSON file as a backup.</p><button onclick="exportData()" class="w-full bg-blue-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-700 transition"><i class="fas fa-download mr-2"></i>Export to File</button></div><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-xl font-bold mb-3 text-gray-700">Import Data</h3><p class="text-sm text-gray-600 mb-4">Load data from a JSON file. This will overwrite current data.</p><input type="file" id="import-file-input" class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" onchange="importData(event)"/></div></div></div><div class="bg-white rounded-xl shadow-lg p-6 md:p-8"><h2 class="text-3xl font-bold text-gray-800 mb-6">Manage Grain Types</h2><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-xl font-bold mb-3 text-gray-700">Add New Grain</h3><div class="flex items-center space-x-2"><input type="text" id="admin-grain-name" placeholder="e.g., Millet" class="w-full border-gray-300 rounded-md p-2"><button onclick="addGrain()" class="bg-green-600 text-white font-bold py-2 px-6 rounded-lg hover:bg-green-700 transition"><i class="fas fa-plus mr-2"></i>Add</button></div></div><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-xl font-bold mb-3 text-gray-700">Current Grains</h3><div id="admin-grain-list" class="space-y-2"></div></div></div></div><div class="bg-white rounded-xl shadow-lg p-6 md:p-8"><h2 class="text-3xl font-bold text-gray-800 mb-6">Create New Locations</h2><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-lg font-bold mb-3 text-gray-700">1. Add State & Warehouse</h3><input type="text" id="admin-state-name" placeholder="New State Name" class="w-full border-gray-300 rounded-md p-2 mb-2"><input type="text" id="admin-warehouse-name" placeholder="Warehouse Name" class="w-full border-gray-300 rounded-md p-2 mb-3"><button onclick="addStateWarehouse()" class="w-full bg-indigo-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-indigo-700 transition"><i class="fas fa-plus mr-2"></i>Create State</button></div><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-lg font-bold mb-3 text-gray-700">2. Add City Hub</h3><select id="admin-city-state-select" class="w-full border-gray-300 rounded-md p-2 mb-2"></select><input type="text" id="admin-hub-name" placeholder="City Hub Name" class="w-full border-gray-300 rounded-md p-2 mb-3"><button onclick="addCityHub()" class="w-full bg-indigo-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-indigo-700 transition"><i class="fas fa-plus mr-2"></i>Create Hub</button></div><div class="bg-gray-50 p-6 rounded-lg border"><h3 class="text-lg font-bold mb-3 text-gray-700">Add Central Godown</h3><input type="text" id="admin-godown-name" placeholder="e.g., FCI Central" class="w-full border-gray-300 rounded-md p-2 mb-3"><button onclick="addCentralGodown()" class="w-full bg-indigo-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-indigo-700 transition"><i class="fas fa-plus mr-2"></i>Create Godown</button></div></div></div><div class="bg-white rounded-xl shadow-lg p-6 md:p-8"><h2 class="text-3xl font-bold text-gray-800 mb-6">Create Fair Price Shop (FPS)</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div><label class="font-semibold text-gray-600">1. Select State & City</label><select id="admin-fps-state-select" class="w-full border-gray-300 rounded-md p-2 mt-1 mb-2"></select><select id="admin-fps-city-select" class="w-full border-gray-300 rounded-md p-2 mt-1"></select></div><div><label class="font-semibold text-gray-600">2. Enter FPS Details</label><input type="text" id="admin-fps-name" placeholder="FPS Name" class="w-full border-gray-300 rounded-md p-2 mt-1"></div><div><label class="font-semibold text-gray-600">3. Set Monthly Demand (Kgs)</label><div id="admin-fps-demand-inputs" class="space-y-1 mt-1"></div></div></div><button onclick="addFPS()" class="w-full mt-6 bg-green-600 text-white font-bold py-3 px-4 rounded-lg hover:bg-green-700 transition text-lg"><i class="fas fa-store mr-2"></i>Create FPS</button></div><div class="bg-white rounded-xl shadow-lg p-6 md:p-8"><h2 class="text-3xl font-bold text-red-700 mb-6">Delete Location</h2><p class="text-gray-600 mb-4 -mt-4">Warning: Deleting a location is permanent. Central Godowns cannot be deleted.</p><div class="flex items-center space-x-4"><select id="admin-delete-select" class="w-full border-gray-300 rounded-md p-3"></select><button onclick="deleteLocation()" class="bg-red-600 text-white font-bold py-2 px-6 rounded-lg hover:bg-red-700 transition"><i class="fas fa-trash-alt mr-2"></i>Delete</button></div></div></div>`
        };
        for (const viewId in viewTemplates) {
            if (document.getElementById(viewId)) {
                document.getElementById(viewId).innerHTML = viewTemplates[viewId];
            }
        }
        
        // Load data from Supabase on page load
        loadDBFromSupabase().then(() => {
            // Initialize user profile after data is loaded
            initializeUserProfile();
            
            // Beneficiary view listeners
            document.getElementById('beneficiary-reg-state-select').addEventListener('change', renderBeneficiaryView);
