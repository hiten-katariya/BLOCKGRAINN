    function renderTransactionView() {
        document.getElementById('ledger-transaction-history-body').innerHTML = (db.transactions || []).map(tx => {
            let rowClass = '', itemsHtml = '';
            const txFrom = tx.from_entity || tx.from || 'N/A';
            const txTo = tx.to_entity || tx.to || 'N/A';
            const confirmationStatus = tx.confirmation_status || tx.confirmationStatus || '';
            const complaintStatus = tx.complaint_status || tx.complaintStatus || '';
            if (tx.type === 'admin') {
                rowClass = 'bg-yellow-50'; itemsHtml = `<div class="font-semibold text-gray-600">${tx.items || 'N/A'}</div>`;
            } else {
                if (txFrom === 'Govt. Procurement' || txFrom === 'Govt Procurement') rowClass = 'bg-green-50';
                if (txTo && txTo.startsWith('Beneficiary')) rowClass = 'bg-blue-50';
                itemsHtml = typeof tx.items === 'object' && tx.items ? Object.entries(tx.items).map(([g, q]) => `<div>${g}: ${(q || 0).toLocaleString()} Kgs</div>`).join('') : '<div>N/A</div>';

                const normalizedStatus = String(confirmationStatus || complaintStatus || '').toLowerCase();
                if (normalizedStatus.includes('pending')) {
                    itemsHtml += '<div class="mt-2 inline-block px-2 py-1 text-xs font-semibold rounded bg-amber-100 text-amber-800">Pending Confirmation</div>';
                } else if (normalizedStatus.includes('verified')) {
                    itemsHtml += '<div class="mt-2 inline-block px-2 py-1 text-xs font-semibold rounded bg-green-100 text-green-800">Verified</div>';
                } else if (normalizedStatus.includes('complaint') || normalizedStatus.includes('raised')) {
                    itemsHtml += '<div class="mt-2 inline-block px-2 py-1 text-xs font-semibold rounded bg-red-100 text-red-800">Complaint Raised</div>';
                }
            }
            return `<tr class="border-b ${rowClass}"><td class="py-3 px-4 font-mono text-xs">${tx.hash || 'N/A'}</td><td class="py-3 px-4 text-sm">${tx.timestamp || 'N/A'}</td><td class="py-3 px-4 text-sm">${txFrom}</td><td class="py-3 px-4 text-sm">${txTo}</td><td class="py-3 px-4 text-sm">${itemsHtml}</td></tr>`;
        }).join('') || '<tr><td colspan="5" class="py-8 text-center text-gray-500">No transactions found</td></tr>';
    }
    
