<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JustRation - Login</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌾</text></svg>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        .login-card {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.95);
            animation: slideUp 0.5s ease-out;
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .role-badge {
            transition: all 0.3s ease;
        }
        .role-badge:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body class="flex items-center justify-center p-4">
    
    <div class="login-card rounded-2xl shadow-2xl p-8 md:p-12 max-w-md w-full">
        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="inline-block bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-full p-4 mb-4">
                <i class="fas fa-cubes-stacked text-5xl"></i>
            </div>
            <h1 class="text-4xl font-extrabold text-gray-800 mb-2">JustRation</h1>
            <p class="text-gray-600">Public Distribution System</p>
        </div>

        <!-- Login Form -->
        <div id="login-form" class="space-y-6">
            <div>
                <label for="userId" class="block text-sm font-semibold text-gray-700 mb-2">User ID</label>
                <input type="text" id="userId" placeholder="Enter your user ID" 
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            </div>
            
            <div>
                <label for="password" class="block text-sm font-semibold text-gray-700 mb-2">Password</label>
                <input type="password" id="password" placeholder="Enter your password" 
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            </div>

            <div id="error-message" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
                <i class="fas fa-exclamation-circle mr-2"></i>
                <span id="error-text">Invalid credentials</span>
            </div>

            <button onclick="handleLogin()" class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold py-3 px-4 rounded-lg hover:from-blue-700 hover:to-indigo-700 transition duration-300 transform hover:scale-105">
                <i class="fas fa-sign-in-alt mr-2"></i>Sign In
            </button>
        </div>

        <!-- Demo Credentials -->
        <div class="mt-8 pt-8 border-t border-gray-200">
            <h3 class="text-sm font-semibold text-gray-700 mb-4 text-center">Demo Credentials</h3>
            <div class="space-y-2 text-xs">
                <div class="role-badge bg-red-50 border border-red-200 p-3 rounded-lg cursor-pointer" onclick="fillCredentials('admin', 'admin123')">
                    <div class="flex justify-between items-center">
                        <div>
                            <span class="font-bold text-red-700">👑 Admin</span>
                            <p class="text-gray-600 text-xs mt-1">Full system access</p>
                        </div>
                        <div class="text-right text-gray-500">
                            <div>ID: <span class="font-mono">admin</span></div>
                            <div>PW: <span class="font-mono">admin123</span></div>
                        </div>
                    </div>
                </div>

                <div class="role-badge bg-blue-50 border border-blue-200 p-3 rounded-lg cursor-pointer" onclick="fillCredentials('central001', 'central123')">
                    <div class="flex justify-between items-center">
                        <div>
                            <span class="font-bold text-blue-700">🏛️ Central Officer</span>
                            <p class="text-gray-600 text-xs mt-1">Full system access</p>
                        </div>
                        <div class="text-right text-gray-500">
                            <div>ID: <span class="font-mono">central001</span></div>
                            <div>PW: <span class="font-mono">central123</span></div>
                        </div>
                    </div>
                </div>

                <div class="role-badge bg-green-50 border border-green-200 p-3 rounded-lg cursor-pointer" onclick="fillCredentials('warehouse001', 'warehouse123')">
                    <div class="flex justify-between items-center">
                        <div>
                            <span class="font-bold text-green-700">🏭 Warehouse Manager</span>
                            <p class="text-gray-600 text-xs mt-1">Dispatch & Distribution</p>
                        </div>
                        <div class="text-right text-gray-500">
                            <div>ID: <span class="font-mono">warehouse001</span></div>
                            <div>PW: <span class="font-mono">warehouse123</span></div>
                        </div>
                    </div>
                </div>

                <div class="role-badge bg-purple-50 border border-purple-200 p-3 rounded-lg cursor-pointer" onclick="fillCredentials('cityhub001', 'cityhub123')">
                    <div class="flex justify-between items-center">
                        <div>
                            <span class="font-bold text-purple-700">🏙️ City Hub Officer</span>
                            <p class="text-gray-600 text-xs mt-1">Distribution access</p>
                        </div>
                        <div class="text-right text-gray-500">
                            <div>ID: <span class="font-mono">cityhub001</span></div>
                            <div>PW: <span class="font-mono">cityhub123</span></div>
                        </div>
                    </div>
                </div>

                <div class="role-badge bg-indigo-50 border border-indigo-200 p-3 rounded-lg cursor-pointer" onclick="fillCredentials('fps001', 'fps123')">
                    <div class="flex justify-between items-center">
                        <div>
                            <span class="font-bold text-indigo-700">🏪 FPS Operator</span>
                            <p class="text-gray-600 text-xs mt-1">Distribution access</p>
                        </div>
                        <div class="text-right text-gray-500">
                            <div>ID: <span class="font-mono">fps001</span></div>
                            <div>PW: <span class="font-mono">fps123</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // User database with role-based permissions
        const users = {
            'admin': {
                password: 'admin123',
                role: 'admin',
                name: 'System Administrator',
                permissions: ['dashboard', 'central-admin', 'godown-to-warehouse', 'warehouse-to-cityhub', 'cityhub-to-fps', 'beneficiary', 'transaction', 'system-admin']
            },
            'central001': {
                password: 'central123',
                role: 'central',
                name: 'Central Officer',
                permissions: ['dashboard', 'central-admin', 'godown-to-warehouse', 'warehouse-to-cityhub', 'cityhub-to-fps', 'beneficiary', 'transaction', 'system-admin']
            },
            'warehouse001': {
                password: 'warehouse123',
                role: 'warehouse',
                name: 'Warehouse Manager',
                permissions: ['warehouse-to-cityhub', 'cityhub-to-fps', 'beneficiary', 'transaction']
            },
            'cityhub001': {
                password: 'cityhub123',
                role: 'cityhub',
                name: 'City Hub Officer',
                permissions: ['cityhub-to-fps', 'beneficiary', 'transaction']
            },
            'fps001': {
                password: 'fps123',
                role: 'fps',
                name: 'FPS Operator',
                permissions: ['beneficiary', 'transaction']
            }
        };

        function fillCredentials(userId, password) {
            document.getElementById('userId').value = userId;
            document.getElementById('password').value = password;
            document.getElementById('userId').focus();
        }

        function showError(message) {
            const errorDiv = document.getElementById('error-message');
            const errorText = document.getElementById('error-text');
            errorText.textContent = message;
            errorDiv.classList.remove('hidden');
            setTimeout(() => errorDiv.classList.add('hidden'), 3000);
        }

        function handleLogin() {
            const userId = document.getElementById('userId').value.trim();
            const password = document.getElementById('password').value;

            if (!userId || !password) {
                showError('Please enter both User ID and Password');
                return;
            }

            const user = users[userId];
            
            if (!user) {
                showError('User ID not found');
                return;
            }

            if (user.password !== password) {
                showError('Incorrect password');
                return;
            }

            // Store user session
            localStorage.setItem('currentUser', JSON.stringify({
                userId: userId,
                name: user.name,
                role: user.role,
                permissions: user.permissions
            }));

            // Redirect to main application
            window.location.href = '/';
        }

        // Handle Enter key
        document.getElementById('password').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') handleLogin();
        });
        document.getElementById('userId').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                document.getElementById('password').focus();
            }
        });

        // Check if already logged in
        if (localStorage.getItem('currentUser')) {
            window.location.href = '/';
        }
    </script>
</body>
</html>
